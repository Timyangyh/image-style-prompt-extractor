{
  "name": "image-style-prompt-extractor",
  "version": "1.1.7",
  "description": "本地图片风格提示词复刻提取工具",
  "main": "./out/main/index.js",
  "author": "图片复刻大师 contributors",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "test:unit": "vitest run src electron",
    "test:e2e:handoff": "npm run build && node scripts/workflow-handoff-e2e.mjs",
    "test:e2e:win": "node scripts/windows-e2e.mjs",
    "verify:release": "bash scripts/verify-public-release.sh",
    "start": "electron-vite preview",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win --x64 --publish never",
    "pack": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^3.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.16",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^39.8.5",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.0.0",
    "playwright-core": "1.61.1",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "local.image-style-prompt-extractor",
    "productName": "图片复刻大师",
    "icon": "assets/app-icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "assets/app-icon.icns",
      "artifactName": "image-style-prompt-extractor-mac-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "assets/app-icon.ico",
      "executableName": "image-style-prompt-extractor",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "image-style-prompt-extractor-win-portable-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "image-style-prompt-extractor-win-setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "图片复刻大师",
      "installerLanguages": [
        "zh_CN"
      ]
    }
  }
}
